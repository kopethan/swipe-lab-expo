diff --git a/apps/web/src/features/onboarding/OnboardingCarousel.tsx b/apps/web/src/features/onboarding/OnboardingCarousel.tsx
new file mode 100644
index 0000000..66c2869
--- /dev/null
+++ b/apps/web/src/features/onboarding/OnboardingCarousel.tsx
@@ -0,0 +1,102 @@
+'use client';
+
+import { useEffect, useMemo, useRef, useState } from 'react';
+import { HELLOWHEN_ONBOARDING_SLIDES } from '@hellowhen/shared';
+import { useWebTranslation } from '../../providers/WebI18nProvider';
+import { markWebOnboardingSeen } from './onboardingStorage';
+import { OnboardingIllustration } from './OnboardingIllustrations';
+
+type OnboardingCarouselProps = {
+  onClose: () => void;
+};
+
+export function OnboardingCarousel({ onClose }: OnboardingCarouselProps) {
+  const { t } = useWebTranslation();
+  const [index, setIndex] = useState(0);
+  const titleRef = useRef<HTMLHeadingElement | null>(null);
+  const slides = HELLOWHEN_ONBOARDING_SLIDES;
+  const slide = slides[index] ?? slides[0];
+  const isFirst = index === 0;
+  const isLast = index === slides.length - 1;
+  const progressLabel = useMemo(() => t('onboarding.progress', { current: index + 1, total: slides.length }), [index, slides.length, t]);
+
+  useEffect(() => {
+    const previousOverflow = document.body.style.overflow;
+    document.body.style.overflow = 'hidden';
+    return () => {
+      document.body.style.overflow = previousOverflow;
+    };
+  }, []);
+
+  useEffect(() => {
+    titleRef.current?.focus();
+  }, [index]);
+
+  useEffect(() => {
+    function handleKeyDown(event: KeyboardEvent) {
+      if (event.key === 'Escape') close();
+      if (event.key === 'ArrowRight') goNext();
+      if (event.key === 'ArrowLeft') goBack();
+    }
+
+    window.addEventListener('keydown', handleKeyDown);
+    return () => window.removeEventListener('keydown', handleKeyDown);
+  });
+
+  function close() {
+    markWebOnboardingSeen();
+    onClose();
+  }
+
+  function goBack() {
+    setIndex((current) => Math.max(0, current - 1));
+  }
+
+  function goNext() {
+    if (isLast) {
+      close();
+      return;
+    }
+    setIndex((current) => Math.min(slides.length - 1, current + 1));
+  }
+
+  return (
+    <section className="onboarding-takeover" aria-label={t('onboarding.brand')} aria-modal="true" role="dialog">
+      <div className="onboarding-takeover__topbar">
+        <span className="onboarding-takeover__brand">{t('onboarding.brand')}</span>
+        <button type="button" className="onboarding-takeover__skip" onClick={close}>{t('onboarding.actions.skip')}</button>
+      </div>
+
+      <div className="onboarding-takeover__content">
+        <div className="onboarding-visual-card">
+          <OnboardingIllustration illustrationKey={slide.illustrationKey} />
+          <p className="onboarding-visual-caption">{t(slide.captionKey)}</p>
+        </div>
+
+        <div className="onboarding-copy-card">
+          <span className="semantic-badge instruction">{progressLabel}</span>
+          <h2 ref={titleRef} tabIndex={-1}>{t(slide.titleKey)}</h2>
+          <p>{t(slide.bodyKey)}</p>
+
+          <div className="onboarding-progress" aria-label={progressLabel}>
+            {slides.map((item, dotIndex) => (
+              <button
+                key={item.id}
+                type="button"
+                className={dotIndex === index ? 'onboarding-progress__dot is-active' : 'onboarding-progress__dot'}
+                onClick={() => setIndex(dotIndex)}
+                aria-label={t('onboarding.progress', { current: dotIndex + 1, total: slides.length })}
+                aria-current={dotIndex === index ? 'step' : undefined}
+              />
+            ))}
+          </div>
+        </div>
+      </div>
+
+      <div className="onboarding-takeover__actions">
+        <button type="button" className="secondary" onClick={goBack} disabled={isFirst}>{t('onboarding.actions.back')}</button>
+        <button type="button" onClick={goNext}>{isLast ? t('onboarding.actions.getStarted') : t('onboarding.actions.next')}</button>
+      </div>
+    </section>
+  );
+}
