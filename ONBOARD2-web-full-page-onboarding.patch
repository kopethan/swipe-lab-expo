@@ -0,0 +1,19 @@
+import { HELLOWHEN_ONBOARDING_SEEN_KEY } from '@hellowhen/shared';
+
+export function hasSeenWebOnboarding() {
+  if (typeof window === 'undefined') return true;
+  try {
+    return window.localStorage.getItem(HELLOWHEN_ONBOARDING_SEEN_KEY) === 'true';
+  } catch {
+    return true;
+  }
+}
+
+export function markWebOnboardingSeen() {
+  if (typeof window === 'undefined') return;
+  try {
+    window.localStorage.setItem(HELLOWHEN_ONBOARDING_SEEN_KEY, 'true');
+  } catch {
+    // Ignore unavailable storage. The current UI close state still lets the user continue.
+  }
+}
