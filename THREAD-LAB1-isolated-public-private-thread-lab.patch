+  id: string;
+  name: string;
+  initials: string;
+  roleLabel: string;
+};
+
+export type ThreadMessage = {
+  id: string;
+  authorId: string;
+  body: string;
+  createdAtLabel: string;
+  edited?: boolean;
+  deleted?: boolean;
+};
+
+export type ThreadLabScenario = {
+  tradeTitle: string;
