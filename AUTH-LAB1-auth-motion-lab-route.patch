+import { Stack, router } from "expo-router";
+import React, { useMemo, useState } from "react";
+import { Platform, Pressable, ScrollView, StyleSheet, Text, View } from "react-native";
+import { useSafeAreaInsets } from "react-native-safe-area-context";
+
+import { useTheme } from "@/providers/ThemeProvider";
+
+type AuthMode = "login" | "register" | "reset";
+type MoodState = "straight" | "smile" | "frown";
+
+type PreviewField = {
+  label: string;
+  placeholder: string;
+  state: MoodState;
+  helper?: string;
+};
+
+const modes: { id: AuthMode; label: string }[] = [
+  { id: "login", label: "Login" },
+  { id: "register", label: "Register" },
+  { id: "reset", label: "Reset" },
+];
+
+const stateCards: { state: MoodState; title: string; description: string; line: string }[] = [
+  {
+    state: "straight",
+    title: "Typing / incomplete",
+    description: "Keep the field stable while the user is still entering information.",
+    line: "────────────",
+  },
+  {
+    state: "smile",
+    title: "Valid / ready",
+    description: "Curve the mood line gently upward after the field passes validation.",
+    line: "╰────────╯",
+  },
+  {
+    state: "frown",
+    title: "Error / failed",
+    description: "Curve the mood line downward, then pair it with clear helper text.",
+    line: "╭────────╮",
+  },
+];
+
+function getModeCopy(mode: AuthMode) {
+  switch (mode) {
+    case "register":
+      return {
+        title: "Create your account",
+        subtitle: "Create your account and set local display preferences for the beta.",
+        button: "Create account",
+      };
+    case "reset":
+      return {
+        title: "Reset your password",
+        subtitle: "Request a reset link for your Hellowhen account.",
+        button: "Send reset link",
+      };
+    case "login":
+    default:
+      return {
+        title: "Welcome back",
+        subtitle: "Sign in to create needs, offers, trades, and proposals.",
+        button: "Login",
+      };
+  }
+}
+
+function getPreviewFields(mode: AuthMode): PreviewField[] {
+  switch (mode) {
+    case "register":
+      return [
+        { label: "Full name", placeholder: "Mina Chen", state: "smile" },
+        { label: "Email", placeholder: "you@example.com", state: "straight" },
+        { label: "Password", placeholder: "At least 8 characters", state: "straight" },
+        {
+          label: "Confirm password",
+          placeholder: "Repeat password",
+          state: "frown",
+          helper: "Passwords should match before the curve turns into a smile.",
+        },
+      ];
+    case "reset":
+      return [
+        {
+          label: "Email",
+          placeholder: "you@example.com",
+          state: "smile",
+          helper: "Reset flow only needs one focused motion test field.",
+        },
+      ];
+    case "login":
+    default:
+      return [
+        { label: "Email", placeholder: "you@example.com", state: "smile" },
+        {
+          label: "Password",
+          placeholder: "At least 8 characters",
+          state: "frown",
+          helper: "Wrong password state should never rely on motion alone.",
+        },
+      ];
+  }
+}
+
+function ModeTabs({ activeMode, onChange }: { activeMode: AuthMode; onChange: (mode: AuthMode) => void }) {
+  const { palette } = useTheme();
+
+  return (
+    <View style={[styles.tabs, { backgroundColor: palette.surfaceAlt }]}>
+      {modes.map((mode) => {
+        const isActive = mode.id === activeMode;
+        return (
+          <Pressable
+            key={mode.id}
+            onPress={() => onChange(mode.id)}
+            accessibilityRole="button"
+            accessibilityState={{ selected: isActive }}
+            style={({ pressed }) => [
+              styles.tab,
+              isActive ? { backgroundColor: palette.surface } : null,
+              pressed ? styles.pressed : null,
+            ]}
+          >
+            <Text style={[styles.tabText, { color: palette.text }]}>{mode.label}</Text>
+          </Pressable>
+        );
+      })}
+    </View>
+  );
+}
+
+function FieldPreview({ field }: { field: PreviewField }) {
+  const { palette } = useTheme();
+  const lineStyle = useMemo(() => {
+    if (field.state === "smile") {
+      return styles.moodLineSmile;
+    }
+
+    if (field.state === "frown") {
+      return styles.moodLineFrown;
+    }
+
+    return styles.moodLineStraight;
+  }, [field.state]);
+
+  return (
+    <View style={styles.fieldBlock}>
+      <Text style={[styles.fieldLabel, { color: palette.text }]}>{field.label}</Text>
+      <View style={[styles.inputShell, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}>
+        <Text style={[styles.placeholder, { color: palette.muted }]}>{field.placeholder}</Text>
+      </View>
+      <View
+        style={[
+          styles.moodLine,
+          lineStyle,
+          {
+            borderColor:
+              field.state === "frown" ? palette.danger : field.state === "smile" ? "#35E6C6" : palette.border,
+          },
+        ]}
+      />
+      {field.helper ? (
+        <Text
+          style={[
+            styles.helper,
+            { color: field.state === "frown" ? palette.danger : palette.muted },
+          ]}
+        >
+          {field.helper}
+        </Text>
+      ) : null}
+    </View>
+  );
+}
+
+function AuthPreview({ mode }: { mode: AuthMode }) {
+  const { palette } = useTheme();
+  const copy = getModeCopy(mode);
+  const fields = getPreviewFields(mode);
+
+  return (
+    <View style={[styles.phoneFrame, { backgroundColor: palette.background, borderColor: palette.border }]}>
+      <View style={styles.previewTopRow}>
+        <View style={[styles.backPill, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}>
+          <Text style={[styles.backPillText, { color: palette.text }]}>Back</Text>
+        </View>
+      </View>
+
+      <View style={[styles.tradeBadge, { borderColor: "rgba(130,80,255,0.65)" }]}>
+        <Text style={styles.tradeBadgeText}>TRADE</Text>
+      </View>
+
+      <Text style={[styles.previewTitle, { color: palette.text }]}>{copy.title}</Text>
+      <Text style={[styles.previewSubtitle, { color: palette.muted }]}>{copy.subtitle}</Text>
+
+      <ModeTabs activeMode={mode} onChange={() => undefined} />
+
+      <View style={styles.previewFields}>
+        {fields.map((field) => (
+          <FieldPreview key={`${mode}-${field.label}`} field={field} />
+        ))}
+      </View>
+
+      <View style={[styles.primaryButton, { backgroundColor: palette.text }]}>
+        <Text style={[styles.primaryButtonText, { color: palette.background }]}>{copy.button}</Text>
+      </View>
+
+      <View style={styles.noticeBox}>
+        <Text style={styles.noticeText}>
+          Google sign-in is disabled for the first launch. Please use email login or create an
+          account with email for now.
+        </Text>
+      </View>
+    </View>
+  );
+}
+
+function MotionStateCard({ title, description, line, state }: (typeof stateCards)[number]) {
+  const { palette } = useTheme();
+
+  return (
+    <View style={[styles.stateCard, { backgroundColor: palette.surface, borderColor: palette.border }]}>
+      <View style={styles.stateCardTopRow}>
+        <Text style={[styles.stateTitle, { color: palette.text }]}>{title}</Text>
+        <Text
+          style={[
+            styles.stateBadge,
+            { color: state === "frown" ? palette.danger : state === "smile" ? "#35E6C6" : palette.muted },
+          ]}
+        >
+          {state.toUpperCase()}
+        </Text>
+      </View>
+      <Text style={[styles.stateLine, { color: palette.text }]}>{line}</Text>
+      <Text style={[styles.stateDescription, { color: palette.muted }]}>{description}</Text>
+    </View>
+  );
+}
+
+export function AuthMotionLabScreen() {
+  const { mode: themeMode, palette, toggleMode } = useTheme();
+  const insets = useSafeAreaInsets();
+  const [activeMode, setActiveMode] = useState<AuthMode>("login");
+
+  return (
+    <View style={[styles.screen, { backgroundColor: palette.background }]}>
+      <Stack.Screen options={{ title: "Auth Motion Lab", headerShown: false }} />
+
+      <View
+        style={[
+          styles.header,
+          {
+            paddingTop: insets.top + 16,
+            borderBottomColor: palette.border,
+            backgroundColor: palette.background,
+          },
+        ]}
+      >
+        <View style={styles.headerTopRow}>
+          <Pressable
+            onPress={() => router.back()}
+            accessibilityRole="button"
+            style={({ pressed }) => [styles.headerButton, { borderColor: palette.border }, pressed ? styles.pressed : null]}
+          >
+            <Text style={[styles.headerButtonText, { color: palette.text }]}>‹ Labs</Text>
+          </Pressable>
+
+          <Pressable
+            onPress={toggleMode}
+            accessibilityRole="button"
+            style={({ pressed }) => [styles.headerButton, { borderColor: palette.border }, pressed ? styles.pressed : null]}
+          >
+            <Text style={[styles.headerButtonText, { color: palette.text }]}>
+              {themeMode === "dark" ? "Light" : "Dark"}
+            </Text>
+          </Pressable>
+        </View>
+
+        <Text style={[styles.eyebrow, { color: palette.muted }]}>AUTH MOTION LAB</Text>
+        <Text style={[styles.title, { color: palette.text }]}>Straight, smile, and frown fields</Text>
+        <Text style={[styles.subtitle, { color: palette.muted }]}>
+          Isolated playground for the playful auth-page curve idea. This first route is static and
+          safe: AUTH-LAB2 can add real animated mood inputs here without touching production auth.
+        </Text>
+      </View>
+
+      <ScrollView contentContainerStyle={[styles.content, { paddingBottom: insets.bottom + 32 }]}>
+        <View style={styles.sectionHeader}>
+          <Text style={[styles.sectionTitle, { color: palette.text }]}>Flow preview</Text>
+          <Text style={[styles.sectionText, { color: palette.muted }]}>
+            Switch between login, register, and reset to test the auth layout target before adding
+            motion.
+          </Text>
+        </View>
+
+        <ModeTabs activeMode={activeMode} onChange={setActiveMode} />
+        <AuthPreview mode={activeMode} />
+
+        <View style={styles.sectionHeader}>
+          <Text style={[styles.sectionTitle, { color: palette.text }]}>Mood states</Text>
+          <Text style={[styles.sectionText, { color: palette.muted }]}>
+            These cards define the three baseline field states for the next animated component.
+          </Text>
+        </View>
+
+        <View style={styles.stateGrid}>
+          {stateCards.map((card) => (
+            <MotionStateCard key={card.state} {...card} />
+          ))}
+        </View>
+      </ScrollView>
+    </View>
+  );
+}
+
