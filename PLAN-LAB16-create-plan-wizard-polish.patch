+function getPlanCreateStepPolishCopy(stepId: PlanCreateStepId) {
+  if (stepId === "basics") {
+    return "Name the plan like a small activity people can understand quickly in the feed.";
+  }
+
+  if (stepId === "mode") {
+    return "Choose the plan world first: offline places, online platforms, or a mixed route.";
+  }
+
+  if (stepId === "places") {
+    return "Pick reusable places from your library, starter templates, or create a new place on the spot.";
+  }
+
+  if (stepId === "arrange") {
+    return "Put places in the right order, then polish the time, note, and visual label for each stop.";
+  }
+
+  return "Review the clean summary card and the visual place cards before opening the mock plan.";
+}
+
+function getPlanCreatePrimaryLabel(stepId: PlanCreateStepId) {
+  if (stepId === "arrange") {
+    return "Review deck";
+  }
+
+  if (stepId === "preview") {
+    return "Open mock plan";
+  }
+
+  return "Continue";
+}
+
+function getCanOpenCreateStep(draft: PlanCreateDraft, targetStepId: PlanCreateStepId) {
+  if (targetStepId === "basics" || targetStepId === "mode") {
+    return true;
+  }
+
+  if (targetStepId === "places") {
+    return getPlanCreateStepValidity(draft, "basics");
+  }
+
+  return getPlanCreateStepValidity(draft, "basics") && getPlanCreateStepValidity(draft, "places");
+}
+
+function getPlanCreateProgressPercent(stepIndex: number) {
+  return `${Math.round(((stepIndex + 1) / planCreateSteps.length) * 100)}%`;
+}
