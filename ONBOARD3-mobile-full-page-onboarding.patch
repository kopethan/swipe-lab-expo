@@ -0,0 +1,39 @@
+import React, { useEffect, useState } from 'react';
+import { OnboardingCarousel } from './OnboardingCarousel';
+import { hasSeenMobileOnboarding } from './onboardingStorage';
+import { betaFeatures } from '../../lib/betaFeatures';
+
+type OnboardingGateProps = {
+  ready: boolean;
+};
+
+export function OnboardingGate({ ready }: OnboardingGateProps) {
+  const [visible, setVisible] = useState(false);
+  const [checked, setChecked] = useState(false);
+
+  useEffect(() => {
+    let mounted = true;
+
+    async function checkOnboarding() {
+      if (!ready || !betaFeatures.onboardingEnabled) {
+        if (mounted) {
+          setVisible(false);
+          setChecked(true);
+        }
+        return;
+      }
+
+      const seen = await hasSeenMobileOnboarding();
+      if (mounted) {
+        setVisible(!seen);
+        setChecked(true);
+      }
+    }
+
+    void checkOnboarding();
+    return () => { mounted = false; };
+  }, [ready]);
+
+  if (!ready || !checked || !visible) return null;
+  return <OnboardingCarousel onClose={() => setVisible(false)} />;
+}
