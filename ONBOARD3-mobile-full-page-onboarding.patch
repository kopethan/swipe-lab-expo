+    proposal: theme.semantic.proposal.bg,
+    warning: theme.semantic.warning.bg,
+    text: theme.color.text,
+    border: theme.color.border,
+  };
+}
+
+function MiniCard({ x, y, width, height, palette, opacity = 1 }: { x: number; y: number; width: number; height: number; palette: ShapePalette; opacity?: number }) {
+  return <Rect x={x} y={y} width={width} height={height} rx={18} fill={palette.card} stroke={palette.border} strokeWidth={2} opacity={opacity} />;
+}
+
+function Line({ x, y, width, palette, opacity = 1 }: { x: number; y: number; width: number; palette: ShapePalette; opacity?: number }) {
+  return <Rect x={x} y={y} width={width} height={8} rx={4} fill={palette.line} opacity={opacity} />;
