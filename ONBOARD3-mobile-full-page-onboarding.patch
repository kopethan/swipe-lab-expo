@@ -0,0 +1,18 @@
+import AsyncStorage from '@react-native-async-storage/async-storage';
+import { HELLOWHEN_ONBOARDING_SEEN_KEY } from '@hellowhen/shared';
+
+export async function hasSeenMobileOnboarding() {
+  try {
+    return (await AsyncStorage.getItem(HELLOWHEN_ONBOARDING_SEEN_KEY)) === 'true';
+  } catch {
+    return true;
+  }
+}
+
+export async function markMobileOnboardingSeen() {
+  try {
+    await AsyncStorage.setItem(HELLOWHEN_ONBOARDING_SEEN_KEY, 'true');
+  } catch {
+    // Ignore unavailable storage. The current UI close state still lets the user continue.
+  }
+}
