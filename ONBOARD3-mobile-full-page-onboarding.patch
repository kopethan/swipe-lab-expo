+
+function ImageBox({ x, y, size, palette }: { x: number; y: number; size: number; palette: ShapePalette }) {
+  return <Rect x={x} y={y} width={size} height={size} rx={10} fill={palette.backdrop} stroke={palette.border} strokeWidth={2} />;
