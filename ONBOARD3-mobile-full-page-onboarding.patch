+import React, { useMemo, useState } from 'react';
+import { Pressable, ScrollView, StyleSheet, Text, View, useWindowDimensions } from 'react-native';
+import { useSafeAreaInsets } from 'react-native-safe-area-context';
+import { HELLOWHEN_ONBOARDING_SLIDES } from '@hellowhen/shared';
+import { useThemeTokens } from '../../providers/ThemeProvider';
+import { useTranslation } from '../../providers/MobileI18nProvider';
+import { markMobileOnboardingSeen } from './onboardingStorage';
+import { OnboardingIllustration } from './OnboardingIllustrations';
+
+type OnboardingCarouselProps = {
+  onClose: () => void;
+};
+
+export function OnboardingCarousel({ onClose }: OnboardingCarouselProps) {
+  const theme = useThemeTokens();
+  const { t } = useTranslation();
+  const insets = useSafeAreaInsets();
+  const { width, height } = useWindowDimensions();
+  const [index, setIndex] = useState(0);
+  const slides = HELLOWHEN_ONBOARDING_SLIDES;
+  const slide = slides[index] ?? slides[0];
+  const isFirst = index === 0;
+  const isLast = index === slides.length - 1;
+  const progressLabel = useMemo(() => t('onboarding.progress', { current: index + 1, total: slides.length }), [index, slides.length, t]);
+  const compact = height < 720;
+  const illustrationHeight = Math.max(210, Math.min(compact ? 250 : 310, height * 0.38));
+  const maxContentWidth = Math.min(width - 32, 520);
+
+  async function close() {
+    await markMobileOnboardingSeen();
+    onClose();
+  }
+
+  function goBack() {
+    setIndex((current) => Math.max(0, current - 1));
+  }
+
+  function goNext() {
+    if (isLast) {
+      void close();
+      return;
+    }
+    setIndex((current) => Math.min(slides.length - 1, current + 1));
+  }
+
+  return (
+    <View
+      accessibilityViewIsModal
+      style={[styles.takeover, { backgroundColor: theme.color.background, paddingTop: Math.max(insets.top, 14), paddingBottom: Math.max(insets.bottom, 14) }]}
+    >
+      <View style={styles.topbar}>
+        <Text style={[styles.brand, { color: theme.color.text }]}>{t('onboarding.brand')}</Text>
+        <Pressable
+          accessibilityRole="button"
+          onPress={() => void close()}
+          style={({ pressed }) => [styles.skipButton, { borderColor: theme.color.border, backgroundColor: theme.color.surface }, pressed && styles.pressed]}
+        >
+          <Text style={[styles.skipText, { color: theme.color.text }]}>{t('onboarding.actions.skip')}</Text>
+        </Pressable>
+      </View>
+
+      <ScrollView
+        bounces={false}
+        contentContainerStyle={[styles.scrollContent, { paddingHorizontal: 16 }]}
+        showsVerticalScrollIndicator={false}
+      >
+        <View style={[styles.content, { maxWidth: maxContentWidth }]}>
+          <View style={[styles.visualCard, { height: illustrationHeight, backgroundColor: theme.color.surface, borderColor: theme.color.border }]}>
+            <OnboardingIllustration illustrationKey={slide.illustrationKey} />
+          </View>
+          <Text style={[styles.caption, { color: theme.color.muted }]}>{t(slide.captionKey)}</Text>
+
+          <View style={styles.copyBlock}>
+            <Text style={[styles.progressText, { color: theme.semantic.proposal.bg }]}>{progressLabel}</Text>
+            <Text accessibilityRole="header" style={[styles.title, { color: theme.color.text }]}>{t(slide.titleKey)}</Text>
+            <Text style={[styles.body, { color: theme.color.muted }]}>{t(slide.bodyKey)}</Text>
+          </View>
+
+          <View accessibilityLabel={progressLabel} style={styles.dots}>
+            {slides.map((item, dotIndex) => {
+              const active = dotIndex === index;
+              return (
+                <Pressable
+                  key={item.id}
+                  accessibilityRole="button"
+                  accessibilityState={{ selected: active }}
+                  accessibilityLabel={t('onboarding.progress', { current: dotIndex + 1, total: slides.length })}
+                  onPress={() => setIndex(dotIndex)}
+                  hitSlop={8}
+                  style={[styles.dotTapTarget]}
+                >
+                  <View style={[styles.dot, { backgroundColor: active ? theme.semantic.proposal.bg : theme.color.border, width: active ? 22 : 8 }]} />
+                </Pressable>
+              );
+            })}
+          </View>
+        </View>
+      </ScrollView>
+
+      <View style={[styles.actions, { borderTopColor: theme.color.border, backgroundColor: theme.color.background }]}>
+        <Pressable
+          accessibilityRole="button"
+          accessibilityState={{ disabled: isFirst }}
+          disabled={isFirst}
+          onPress={goBack}
+          style={({ pressed }) => [
+            styles.secondaryButton,
+            { borderColor: theme.color.border, opacity: isFirst ? 0.45 : 1 },
+            pressed && !isFirst && styles.pressed,
+          ]}
+        >
+          <Text style={[styles.secondaryText, { color: theme.color.text }]}>{t('onboarding.actions.back')}</Text>
+        </Pressable>
+        <Pressable
+          accessibilityRole="button"
+          onPress={goNext}
+          style={({ pressed }) => [styles.primaryButton, { backgroundColor: theme.color.text }, pressed && styles.pressed]}
+        >
+          <Text style={[styles.primaryText, { color: theme.color.background }]}>{isLast ? t('onboarding.actions.getStarted') : t('onboarding.actions.next')}</Text>
+        </Pressable>
+      </View>
+    </View>
+  );
+}
+
+const styles = StyleSheet.create({
+  takeover: {
+    ...StyleSheet.absoluteFillObject,
+    zIndex: 1000,
+    elevation: 1000,
+  },
+  topbar: {
+    minHeight: 52,
+    flexDirection: 'row',
+    alignItems: 'center',
+    justifyContent: 'space-between',
+    paddingHorizontal: 20,
+    gap: 12,
+  },
+  brand: { fontSize: 18, lineHeight: 24, fontWeight: '900', letterSpacing: -0.3 },
+  skipButton: { minHeight: 40, borderRadius: 999, borderWidth: 1, paddingHorizontal: 14, alignItems: 'center', justifyContent: 'center' },
+  skipText: { fontSize: 13, lineHeight: 17, fontWeight: '900' },
+  scrollContent: { flexGrow: 1, justifyContent: 'center', paddingBottom: 20 },
+  content: { width: '100%', alignSelf: 'center', alignItems: 'center' },
+  visualCard: { width: '100%', borderRadius: 34, borderWidth: 1, overflow: 'hidden', alignItems: 'center', justifyContent: 'center', paddingHorizontal: 8 },
+  caption: { marginTop: 12, fontSize: 13, lineHeight: 18, fontWeight: '800', textAlign: 'center' },
+  copyBlock: { width: '100%', alignItems: 'center', marginTop: 22, gap: 8 },
+  progressText: { fontSize: 12, lineHeight: 16, fontWeight: '900', letterSpacing: 0.8, textTransform: 'uppercase' },
+  title: { fontSize: 31, lineHeight: 36, fontWeight: '900', letterSpacing: -0.9, textAlign: 'center' },
+  body: { fontSize: 16, lineHeight: 23, fontWeight: '700', textAlign: 'center', maxWidth: 430 },
+  dots: { flexDirection: 'row', alignItems: 'center', justifyContent: 'center', gap: 3, marginTop: 24 },
+  dotTapTarget: { minWidth: 22, minHeight: 22, alignItems: 'center', justifyContent: 'center' },
+  dot: { height: 8, borderRadius: 999 },
+  actions: { flexDirection: 'row', alignItems: 'center', gap: 12, paddingHorizontal: 20, paddingTop: 14, borderTopWidth: StyleSheet.hairlineWidth },
+  primaryButton: { flex: 1, minHeight: 52, borderRadius: 18, alignItems: 'center', justifyContent: 'center', paddingHorizontal: 18 },
+  secondaryButton: { minWidth: 108, minHeight: 52, borderRadius: 18, borderWidth: 1, alignItems: 'center', justifyContent: 'center', paddingHorizontal: 18 },
+  primaryText: { fontSize: 15, lineHeight: 20, fontWeight: '900' },
+  secondaryText: { fontSize: 15, lineHeight: 20, fontWeight: '900' },
+  pressed: { opacity: 0.78, transform: [{ scale: 0.98 }] },
+});
