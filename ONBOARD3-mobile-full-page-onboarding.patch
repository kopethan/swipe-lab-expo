+type ShapePalette = {
+  backdrop: string;
+  card: string;
+  cardAlt: string;
+  line: string;
+  mutedLine: string;
+  need: string;
+  offer: string;
+  proposal: string;
+  warning: string;
+  text: string;
+  border: string;
+};
+
+function usePalette(): ShapePalette {
+  const theme = useThemeTokens();
+  return {
+    backdrop: theme.color.subtleSurface,
+    card: theme.color.elevated,
+    cardAlt: theme.color.surface,
+    line: theme.color.border,
+    mutedLine: theme.color.muted,
+    need: theme.semantic.need.bg,
