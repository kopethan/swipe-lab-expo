+function getTabTitle(tabId: NavLabTabId) {
+  return navLabTabs.find((tab) => tab.id === tabId)?.label ?? "Me";
+}
+
+function LabHeader({ activeTab, isDesktop }: { activeTab: NavLabTabId; isDesktop: boolean }) {
