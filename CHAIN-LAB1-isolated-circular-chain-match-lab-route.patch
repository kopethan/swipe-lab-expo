+import { Stack, router } from "expo-router";
+import React, { useMemo, useState } from "react";
+import {
+  Platform,
+  Pressable,
+  ScrollView,
+  StyleSheet,
+  Text,
+  useWindowDimensions,
+  View,
+} from "react-native";
+import { useSafeAreaInsets } from "react-native-safe-area-context";
+
+import { useTheme } from "@/providers/ThemeProvider";
+
+import { chainLabScenario } from "./chainLab.mockData";
+import type { ChainParticipant, ChainParticipantId } from "./chainLab.types";
+
+type Point = {
+  x: number;
+  y: number;
+};
+
+type NodePlacement = Point & {
+  participant: ChainParticipant;
+};
+
+const NODE_SIZE = 82;
+const NODE_SIZE_COMPACT = 74;
+
+function getParticipant(participantId: ChainParticipantId) {
+  const participant = chainLabScenario.participants.find((item) => item.id === participantId);
+
+  if (!participant) {
+    throw new Error(`Missing chain participant: ${participantId}`);
+  }
+
+  return participant;
+}
+
+function getConnectionLabel(participant: ChainParticipant) {
+  const from = getParticipant(participant.receivesFromId).name;
+  const to = getParticipant(participant.givesToId).name;
+
+  return `${from} -> ${participant.name} -> ${to}`;
+}
+
+function ScreenHeader() {
+  const { mode, palette, toggleMode } = useTheme();
+  const insets = useSafeAreaInsets();
+
+  return (
+    <View style={[styles.header, { borderBottomColor: palette.border, paddingTop: insets.top + 16 }]}>
+      <View style={styles.headerTopRow}>
+        <Pressable
+          onPress={() => router.back()}
+          accessibilityRole="button"
+          style={({ pressed }) => [styles.textButton, pressed ? styles.pressed : null]}
+        >
+          <Text style={[styles.textButtonLabel, { color: palette.text }]}>{"< Labs"}</Text>
+        </Pressable>
+
+        <Pressable
+          onPress={toggleMode}
+          accessibilityRole="button"
+          style={({ pressed }) => [styles.textButton, pressed ? styles.pressed : null]}
+        >
+          <Text style={[styles.textButtonLabel, { color: palette.text }]}>
+            {mode === "dark" ? "Light" : "Dark"}
+          </Text>
+        </Pressable>
+      </View>
+
+      <View style={styles.titleRow}>
+        <View style={styles.titleBlock}>
+          <Text style={[styles.eyebrow, { color: palette.muted }]}>CHAIN LAB</Text>
+          <Text style={[styles.title, { color: palette.text }]}>{chainLabScenario.title}</Text>
+          <Text style={[styles.subtitle, { color: palette.muted }]}>{chainLabScenario.subtitle}</Text>
+        </View>
+        <View
+          style={[
+            styles.statusPill,
+            { borderColor: palette.border, backgroundColor: palette.surfaceAlt },
+          ]}
+        >
+          <Text style={[styles.statusPillText, { color: palette.text }]}>
+            {chainLabScenario.statusLabel}
+          </Text>
+        </View>
+      </View>
+    </View>
+  );
+}
+
+function ConnectionLine({ from, to, color }: { from: Point; to: Point; color: string }) {
+  const dx = to.x - from.x;
+  const dy = to.y - from.y;
+  const length = Math.sqrt(dx * dx + dy * dy);
+  const angle = Math.atan2(dy, dx);
+  const startOffset = NODE_SIZE * 0.44;
+  const endOffset = NODE_SIZE * 0.48;
+  const visibleLength = Math.max(0, length - startOffset - endOffset);
+  const centerX = from.x + Math.cos(angle) * (startOffset + visibleLength / 2);
+  const centerY = from.y + Math.sin(angle) * (startOffset + visibleLength / 2);
+  const arrowX = from.x + Math.cos(angle) * (startOffset + visibleLength * 0.78);
+  const arrowY = from.y + Math.sin(angle) * (startOffset + visibleLength * 0.78);
+
+  return (
+    <>
+      <View
+        pointerEvents="none"
+        style={[
+          styles.connectionLine,
+          {
+            left: centerX - visibleLength / 2,
+            top: centerY,
+            width: visibleLength,
+            backgroundColor: color,
+            transform: [{ rotate: `${angle}rad` }],
+          },
+        ]}
+      />
+      <Text
+        pointerEvents="none"
+        style={[
+          styles.connectionArrow,
+          {
+            left: arrowX - 7,
+            top: arrowY - 11,
+            color,
+            transform: [{ rotate: `${angle}rad` }],
+          },
+        ]}
+      >
+        {">"}
+      </Text>
+    </>
+  );
+}
+
+function ParticipantNode({
+  placement,
+  selected,
+  currentUser,
+  onPress,
+}: {
+  placement: NodePlacement;
+  selected: boolean;
+  currentUser: boolean;
+  onPress: () => void;
+}) {
+  const { palette } = useTheme();
+  const nodeSize = currentUser ? NODE_SIZE : NODE_SIZE_COMPACT;
+  const participant = placement.participant;
+
+  return (
+    <Pressable
+      onPress={onPress}
+      accessibilityRole="button"
+      accessibilityLabel={`Show ${participant.name} in the chain`}
+      style={({ pressed }) => [
+        styles.node,
+        {
+          left: placement.x - nodeSize / 2,
+          top: placement.y - nodeSize / 2,
+          width: nodeSize,
+          height: nodeSize,
+          borderRadius: nodeSize / 2,
+          borderColor: selected ? palette.text : palette.border,
+          backgroundColor: selected ? palette.text : palette.surface,
+        },
+        currentUser ? styles.currentUserNode : null,
+        pressed ? styles.nodePressed : null,
+      ]}
+    >
+      <Text style={[styles.nodeInitials, { color: selected ? palette.background : palette.text }]}>
+        {participant.initials}
+      </Text>
+      <Text
+        numberOfLines={1}
+        style={[styles.nodeName, { color: selected ? palette.background : palette.text }]}
+      >
+        {participant.name}
+      </Text>
+      {participant.joined ? (
+        <View
+          style={[
+            styles.joinedDot,
+            { borderColor: selected ? palette.text : palette.surface, backgroundColor: palette.text },
+          ]}
+        >
+          <Text style={[styles.joinedDotText, { color: palette.background }]}>✓</Text>
+        </View>
+      ) : null}
+    </Pressable>
+  );
+}
+
+function ChainCircle({
+  selectedId,
+  onSelect,
+}: {
+  selectedId: ChainParticipantId;
+  onSelect: (participantId: ChainParticipantId) => void;
+}) {
+  const { palette } = useTheme();
+  const { width } = useWindowDimensions();
+  const diagramSize = Math.min(Math.max(width - 40, 280), 380);
+  const radius = diagramSize * 0.32;
+  const center = diagramSize / 2;
+
+  const placements = useMemo<NodePlacement[]>(() => {
+    return chainLabScenario.order.map((participantId, index) => {
+      const angle = -Math.PI / 2 + index * ((Math.PI * 2) / chainLabScenario.order.length);
+      const participant = getParticipant(participantId);
+
+      return {
+        participant,
+        x: center + Math.cos(angle) * radius,
+        y: center + Math.sin(angle) * radius,
+      };
+    });
+  }, [center, radius]);
+
+  return (
+    <View style={[styles.circleWrap, { width: diagramSize, height: diagramSize }]}>
+      <View
+        pointerEvents="none"
+        style={[
+          styles.circleGhost,
+          {
+            left: center - radius,
+            top: center - radius,
+            width: radius * 2,
+            height: radius * 2,
+            borderRadius: radius,
+            borderColor: palette.border,
+          },
+        ]}
+      />
+
+      {placements.map((placement, index) => {
+        const nextPlacement = placements[(index + 1) % placements.length];
+        return (
+          <ConnectionLine
+            key={`${placement.participant.id}-${nextPlacement.participant.id}`}
+            from={placement}
+            to={nextPlacement}
+            color={
+              placement.participant.id === selectedId || nextPlacement.participant.id === selectedId
+                ? palette.text
+                : palette.border
+            }
+          />
+        );
+      })}
+
+      {placements.map((placement) => (
+        <ParticipantNode
+          key={placement.participant.id}
+          placement={placement}
+          selected={placement.participant.id === selectedId}
+          currentUser={placement.participant.id === chainLabScenario.currentUserId}
+          onPress={() => onSelect(placement.participant.id)}
+        />
+      ))}
+    </View>
+  );
+}
+
+function InfoChip({ label }: { label: string }) {
+  const { palette } = useTheme();
+
+  return (
+    <View style={[styles.infoChip, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}>
+      <Text style={[styles.infoChipText, { color: palette.text }]}>{label}</Text>
+    </View>
+  );
+}
+
+function RoleLine({
+  label,
+  title,
+  caption,
+}: {
+  label: string;
+  title: string;
+  caption: string;
+}) {
+  const { palette } = useTheme();
+
+  return (
+    <View style={styles.roleLine}>
+      <Text style={[styles.roleLabel, { color: palette.muted }]}>{label}</Text>
+      <Text style={[styles.roleTitle, { color: palette.text }]}>{title}</Text>
+      <Text style={[styles.roleCaption, { color: palette.muted }]}>{caption}</Text>
+    </View>
+  );
+}
+
+function SelectedParticipantCard({ participant }: { participant: ChainParticipant }) {
+  const { palette } = useTheme();
+  const receivesFrom = getParticipant(participant.receivesFromId);
+  const givesTo = getParticipant(participant.givesToId);
+
+  return (
+    <View style={[styles.detailCard, { borderColor: palette.border, backgroundColor: palette.surface }]}>
+      <View style={styles.detailHeaderRow}>
+        <View>
+          <Text style={[styles.detailEyebrow, { color: palette.muted }]}>{participant.roleLabel}</Text>
+          <Text style={[styles.detailTitle, { color: palette.text }]}>{participant.name}</Text>
+        </View>
+        <View style={[styles.miniAvatar, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}>
+          <Text style={[styles.miniAvatarText, { color: palette.text }]}>{participant.initials}</Text>
+        </View>
+      </View>
+
+      <View style={[styles.connectionSummary, { borderColor: palette.border }]}>
+        <Text style={[styles.connectionSummaryText, { color: palette.muted }]}>
+          {getConnectionLabel(participant)}
+        </Text>
+      </View>
+
+      <RoleLine
+        label="Receives"
+        title={participant.needTitle}
+        caption={`from ${receivesFrom.name}`}
+      />
+      <View style={[styles.inlineDivider, { backgroundColor: palette.border }]} />
+      <RoleLine label="Gives" title={participant.offerTitle} caption={`to ${givesTo.name}`} />
+
+      <View style={styles.infoChipsRow}>
+        <InfoChip label={participant.timingLabel} />
+        <InfoChip label={participant.modeLabel} />
+        <InfoChip label={participant.effortLabel} />
+      </View>
+    </View>
+  );
+}
+
+function ActionFooter() {
+  const { palette } = useTheme();
+
+  return (
+    <View style={styles.actionsRow}>
+      <Pressable
+        accessibilityRole="button"
+        style={({ pressed }) => [
+          styles.primaryAction,
+          { backgroundColor: palette.text },
+          pressed ? styles.pressed : null,
+        ]}
+      >
+        <Text style={[styles.primaryActionText, { color: palette.background }]}>I’m interested</Text>
+      </Pressable>
+      <Pressable
+        accessibilityRole="button"
+        style={({ pressed }) => [
+          styles.secondaryAction,
+          { borderColor: palette.border, backgroundColor: palette.surface },
+          pressed ? styles.pressed : null,
+        ]}
+      >
+        <Text style={[styles.secondaryActionText, { color: palette.text }]}>Not for me</Text>
+      </Pressable>
+    </View>
+  );
+}
+
+function ChainTips() {
+  const { palette } = useTheme();
+
+  return (
+    <View style={[styles.tipsCard, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}>
+      <Text style={[styles.tipsTitle, { color: palette.text }]}>Design rule tested here</Text>
+      <Text style={[styles.tipsText, { color: palette.muted }]}>
+        Circle = relationship map. The card below = selected person details. This keeps the chain
+        visual on mobile without crowding the diagram.
+      </Text>
+    </View>
+  );
+}
+
+export function ChainLabScreen() {
+  const { palette } = useTheme();
+  const { width } = useWindowDimensions();
+  const [selectedId, setSelectedId] = useState<ChainParticipantId>(chainLabScenario.currentUserId);
+  const selectedParticipant = getParticipant(selectedId);
+  const isDesktop = Platform.OS === "web" && width >= 820;
+
+  return (
+    <View style={[styles.screen, { backgroundColor: palette.background }]}>
+      <Stack.Screen options={{ title: "Chain Match Lab", headerShown: false }} />
+      <ScreenHeader />
+
+      <ScrollView
+        showsVerticalScrollIndicator={false}
+        contentContainerStyle={[styles.content, isDesktop ? styles.contentDesktop : null]}
+      >
+        <View style={styles.introBlock}>
+          <Text style={[styles.introTitle, { color: palette.text }]}>Circular chain selector</Text>
+          <Text style={[styles.introText, { color: palette.muted }]}>
+            {chainLabScenario.helperText}
+          </Text>
+        </View>
+
+        <View
+          style={[
+            styles.labPanel,
+            isDesktop ? styles.labPanelDesktop : null,
+            { borderColor: palette.border, backgroundColor: palette.surfaceAlt },
+          ]}
+        >
+          <View style={[styles.mapPane, isDesktop ? styles.mapPaneDesktop : null]}>
+            <ChainCircle selectedId={selectedId} onSelect={setSelectedId} />
+          </View>
+
+          <View style={[styles.detailsPane, isDesktop ? styles.detailsPaneDesktop : null]}>
+            <SelectedParticipantCard participant={selectedParticipant} />
+            <ActionFooter />
+          </View>
+        </View>
+
+        <ChainTips />
+      </ScrollView>
+    </View>
+  );
+}
