+const BLUR_SLICE_COUNT = 10;
+
+type LowerAtmosphereProps = {
+  source?: { uri: string };
+  accent: string;
+  isDark: boolean;
+};
+
+function LowerAtmosphere({ source, accent, isDark }: LowerAtmosphereProps) {
+  const slices = useMemo(() => Array.from({ length: BLUR_SLICE_COUNT }, (_, index) => index), []);
+  const tintBase = isDark ? "rgba(4,6,9,0.70)" : "rgba(255,255,255,0.58)";
+  const warmthTint = isDark ? "rgba(0,0,0,0.26)" : "rgba(255,255,255,0.26)";
+
+  return (
+    <View pointerEvents="none" style={styles.lowerAtmosphere}>
+      {source ? (
+        slices.map((slice) => {
+          const progress = (slice + 1) / BLUR_SLICE_COUNT;
+          const eased = progress * progress * (3 - 2 * progress);
+          const sliceHeight = 100 / BLUR_SLICE_COUNT;
+
+          return (
+            <React.Fragment key={`atmosphere-slice-${slice}`}>
+              <View
+                style={[
+                  styles.atmosphereSlice,
+                  {
+                    top: `${slice * sliceHeight}%`,
+                    height: `${sliceHeight + 2}%`,
+                    opacity: 0.08 + eased * 0.68,
+                  },
+                ]}
+              >
+                <Image
+                  source={source}
+                  contentFit="cover"
+                  transition={0}
+                  blurRadius={5 + eased * 18}
+                  style={StyleSheet.absoluteFillObject}
+                />
+              </View>
+              <View
+                style={[
+                  styles.atmosphereSlice,
+                  {
+                    top: `${slice * sliceHeight}%`,
+                    height: `${sliceHeight + 2}%`,
+                    backgroundColor: tintBase,
+                    opacity: 0.04 + eased * 0.62,
+                  },
+                ]}
+              />
+            </React.Fragment>
+          );
+        })
+      ) : (
+        <View style={[StyleSheet.absoluteFillObject, { backgroundColor: isDark ? "rgba(3,5,8,0.56)" : "rgba(255,255,255,0.54)" }]} />
+      )}
+
+      <View style={[styles.atmosphereAccentWash, { backgroundColor: accent }]} />
+      <View style={[StyleSheet.absoluteFillObject, { backgroundColor: warmthTint }]} />
+    </View>
+  );
+}
