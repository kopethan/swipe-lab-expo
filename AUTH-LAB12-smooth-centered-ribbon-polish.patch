+function getRibbonDisplaySegments(value: string, isSecure: boolean) {
+  const characters = Array.from(value);
+
+  if (characters.length === 0) {
+    return [];
+  }
+
+  if (isSecure || characters.length <= 5) {
+    return [value];
+  }
+
+  const segmentCount = Math.min(5, Math.max(3, Math.ceil(characters.length / 5)));
+  const baseSize = Math.ceil(characters.length / segmentCount);
+  const segments: string[] = [];
+
+  for (let index = 0; index < characters.length; index += baseSize) {
+    segments.push(characters.slice(index, index + baseSize).join(""));
+  }
+
+  return segments;
+}
