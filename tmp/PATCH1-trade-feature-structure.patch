+import React, { useMemo, useState } from "react";
+import { Pressable, StyleSheet, Text, View } from "react-native";
+
+import { SwipeDeck } from "@/features/deck";
+import { DeckProbeCard } from "@/components/deck-probe-card";
+import { DebugPanel } from "@/components/debug-panel";
+import { useTheme } from "@/providers/ThemeProvider";
+import {
+  makeMetrics,
+  makeParagraphs,
+  makeSubtitle,
+  makeTags,
+  makeTitle,
+  type FakeMetric,
+} from "@/lib/fakeContent";
+
+type FakeFeedCard = {
+  id: string;
+  title: string;
+  subtitle: string;
+  tags: string[];
+  paragraphs: string[];
+  metrics: FakeMetric[];
+};
+
+function Chip({ text }: { text: string }) {
+  const { palette } = useTheme();
+  return (
+    <View style={[styles.chip, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}
+    >
+      <Text style={[styles.chipText, { color: palette.text }]} numberOfLines={1}>
+        {text}
+      </Text>
+    </View>
+  );
+}
+
+function MetricPill({ m }: { m: FakeMetric }) {
+  const { palette } = useTheme();
+  return (
+    <View style={[styles.metric, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}>
+      <Text style={[styles.metricLabel, { color: palette.muted }]} numberOfLines={1}>
+        {m.label}
+      </Text>
+      <Text style={[styles.metricValue, { color: palette.text }]} numberOfLines={1}>
+        {m.value}
+      </Text>
+    </View>
+  );
+}
+
+function FakeCardBody({ card, index, total }: { card: FakeFeedCard; index: number; total: number }) {
+  const { palette } = useTheme();
+
+  return (
+    <View style={styles.body}>
+      {/* Big identity header: makes "wrong content flashes" obvious */}
+      <View style={styles.header}>
+        <Text style={[styles.kicker, { color: palette.muted }]}>{`CARD ${String(index + 1).padStart(2, "0")} / ${String(
+          total
+        ).padStart(2, "0")}`}</Text>
+        <Text style={[styles.id, { color: palette.text }]}>{card.id.toUpperCase()}</Text>
+      </View>
+
+      <Text style={[styles.title, { color: palette.text }]} numberOfLines={2}>
+        {card.title}
+      </Text>
+      <Text style={[styles.subtitle, { color: palette.muted }]} numberOfLines={2}>
+        {card.subtitle}
+      </Text>
+
+      <View style={styles.tagsRow}>
+        {card.tags.map((t) => (
+          <Chip key={t} text={t} />
+        ))}
+      </View>
+
+      {/* Probe: detects remount / fast reload */}
+      <DeckProbeCard cardId={`feed-${card.id}`} label="FEED" />
+
+      <View style={styles.paragraphs}>
+        {card.paragraphs.map((p, i) => (
+          <Text key={`${card.id}-p-${i}`} style={[styles.paragraph, { color: palette.muted }]}>
+            {p}
+          </Text>
+        ))}
+      </View>
+
+      <View style={styles.metricsRow}>
+        {card.metrics.map((m) => (
+          <MetricPill key={`${card.id}-${m.label}`} m={m} />
+        ))}
+      </View>
+
+      <View style={styles.bottom}>
+        <Pressable
+          onPress={() => console.log("open details", card.id)}
+          hitSlop={10}
+          style={({ pressed }) => [
+            styles.cta,
+            { borderColor: palette.border, backgroundColor: palette.surfaceAlt },
+            pressed ? { opacity: 0.85, transform: [{ scale: 0.99 }] } : null,
+          ]}
+        >
+          <Text style={[styles.ctaText, { color: palette.text }]}>Open details</Text>
+        </Pressable>
+      </View>
+    </View>
+  );
+}
+
+export function TradeHome() {
+  const { palette } = useTheme();
+
+  const [renderBackBodies, setRenderBackBodies] = useState(true);
+  const [useContentOwnerGating, setUseContentOwnerGating] = useState(true);
+
+  const cards: FakeFeedCard[] = useMemo(() => {
+    const count = 12;
+    return Array.from({ length: count }, (_, i) => {
+      const id = `c${String(i + 1).padStart(2, "0")}`;
+      const seed = `feed:${id}`;
+      return {
+        id,
+        title: makeTitle(seed),
+        subtitle: makeSubtitle(seed),
+        tags: makeTags(seed, 3),
+        paragraphs: makeParagraphs(seed, 2),
+        metrics: makeMetrics(seed),
+      };
+    });
+  }, []);
+
+  return (
+    <View style={[styles.screen, { backgroundColor: palette.background }]}>
+      <View style={styles.debugWrap} pointerEvents="box-none">
+        <View style={styles.debugPanel}>
+          <DebugPanel
+            title="Feed deck A/B"
+            note="Flip one toggle, swipe, come back to the same card."
+            toggles={[
+              {
+                key: "backBodies",
+                label: "Render back card bodies",
+                value: renderBackBodies,
+                onChange: setRenderBackBodies,
+              },
+              {
+                key: "gating",
+                label: "Use content-owner gating",
+                value: useContentOwnerGating,
+                onChange: setUseContentOwnerGating,
+              },
+            ]}
+          />
+        </View>
+      </View>
+      <View style={styles.stage}>
+        <SwipeDeck
+          cards={cards}
+          onCardPress={(_, card) => console.log("press", card.id)}
+          renderCard={({ card, index }) => <FakeCardBody card={card} index={index} total={cards.length} />}
+          debug={{ renderBackCardBodies: renderBackBodies, useContentOwnerGating }}
+        />
+      </View>
+    </View>
+  );
+}
+
+export default TradeHome;
+
+const styles = StyleSheet.create({
+  screen: {
+    flex: 1,
+  },
+  stage: {
+    flex: 1,
+    alignItems: "center",
+    justifyContent: "center",
+    paddingHorizontal: 18,
+  },
+
+  debugWrap: {
+    position: "absolute",
+    top: 14,
+    left: 14,
+    right: 14,
+    zIndex: 9999,
+    alignItems: "flex-start",
+  },
+  debugPanel: {
+    pointerEvents: "auto",
+  },
+
+  body: {
+    flex: 1,
+    paddingHorizontal: 18,
+    paddingVertical: 16,
+    gap: 10,
+  },
+
+  header: {
+    flexDirection: "row",
+    alignItems: "baseline",
+    justifyContent: "space-between",
+    gap: 12,
+  },
+  kicker: {
+    fontSize: 10,
+    fontWeight: "900",
+    letterSpacing: 1.2,
+  },
+  id: {
+    fontSize: 18,
+    fontWeight: "900",
+    letterSpacing: -0.4,
+    fontVariant: ["tabular-nums"],
+  },
+  title: {
+    fontSize: 22,
+    fontWeight: "900",
+    letterSpacing: -0.4,
+    lineHeight: 26,
+  },
+  subtitle: {
+    fontSize: 12,
+    fontWeight: "800",
+    letterSpacing: 0.2,
+    lineHeight: 16,
+  },
+
+  tagsRow: {
+    flexDirection: "row",
+    flexWrap: "wrap",
+    gap: 8,
+  },
+  chip: {
+    borderWidth: 1,
+    borderRadius: 999,
+    paddingHorizontal: 10,
+    paddingVertical: 6,
+  },
+  chipText: {
+    fontSize: 11,
+    fontWeight: "900",
+    letterSpacing: 0.2,
+  },
+
+  paragraphs: {
+    gap: 8,
+  },
+  paragraph: {
+    fontSize: 12,
+    lineHeight: 16,
+    fontWeight: "700",
+  },
+
+  metricsRow: {
+    flexDirection: "row",
+    flexWrap: "wrap",
+    gap: 10,
+  },
+  metric: {
+    borderWidth: 1,
+    borderRadius: 14,
+    paddingHorizontal: 12,
+    paddingVertical: 10,
+    minWidth: 96,
+  },
+  metricLabel: {
+    fontSize: 10,
+    fontWeight: "900",
+    letterSpacing: 0.8,
+    textTransform: "uppercase",
+  },
+  metricValue: {
+    marginTop: 6,
+    fontSize: 14,
+    fontWeight: "900",
+    fontVariant: ["tabular-nums"],
+  },
+
+  bottom: {
+    flex: 1,
+    justifyContent: "flex-end",
+    paddingTop: 6,
+  },
+  cta: {
+    alignSelf: "center",
+    borderWidth: 1,
+    borderRadius: 999,
+    paddingHorizontal: 16,
+    paddingVertical: 12,
+  },
+  ctaText: {
+    fontSize: 12,
+    fontWeight: "900",
+    letterSpacing: 0.3,
+  },
+});
