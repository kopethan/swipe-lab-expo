@@ -0,0 +1,327 @@
+import React from "react";
+import { StyleSheet, Text, View } from "react-native";
+
+import { useTheme } from "@/providers/ThemeProvider";
+import type { TradeCategory, TradeFeedItem, TradeServiceMode, TradeUrgency } from "../types";
+
+type TradeFeedCardProps = {
+  item: TradeFeedItem;
+  index?: number;
+  total?: number;
+};
+
+type TradeZoneKind = "need" | "offer";
+
+const CATEGORY_LABELS: Record<TradeCategory, string> = {
+  design: "Design",
+  development: "Development",
+  marketing: "Marketing",
+  writing: "Writing",
+  "photo-video": "Photo / Video",
+  language: "Language",
+  "home-help": "Home help",
+  teaching: "Teaching",
+  business: "Business",
+  other: "Other",
+};
+
+const MODE_LABELS: Record<TradeServiceMode, string> = {
+  remote: "Remote",
+  local: "Local",
+  hybrid: "Hybrid",
+};
+
+const URGENCY_LABELS: Record<TradeUrgency, string> = {
+  low: "Low urgency",
+  medium: "Medium urgency",
+  high: "High urgency",
+  urgent: "Urgent",
+};
+
+function compactMeta(parts: Array<string | undefined>) {
+  return parts.filter(Boolean).join(" · ");
+}
+
+function TradeTag({ label }: { label: string }) {
+  const { palette } = useTheme();
+
+  return (
+    <View style={[styles.tag, { borderColor: palette.border, backgroundColor: palette.surface }]}>
+      <Text style={[styles.tagText, { color: palette.text }]} numberOfLines={1}>
+        {label}
+      </Text>
+    </View>
+  );
+}
+
+function TradeZone({
+  kind,
+  title,
+  subtitle,
+  meta,
+  tags,
+}: {
+  kind: TradeZoneKind;
+  title: string;
+  subtitle?: string;
+  meta: string;
+  tags?: string[];
+}) {
+  const { palette } = useTheme();
+  const label = kind === "need" ? "NEED" : "OFFER";
+  const headline = kind === "need" ? "I need" : "I offer";
+  const visibleTags = tags?.slice(0, 2) ?? [];
+
+  return (
+    <View style={[styles.zone, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}>
+      <View style={styles.zoneHeader}>
+        <View style={[styles.zoneBadge, { borderColor: palette.border, backgroundColor: palette.surface }]}>
+          <Text style={[styles.zoneBadgeText, { color: palette.muted }]} numberOfLines={1}>
+            {label}
+          </Text>
+        </View>
+        <Text style={[styles.zoneHeadline, { color: palette.muted }]} numberOfLines={1}>
+          {headline}
+        </Text>
+      </View>
+
+      <Text style={[styles.zoneTitle, { color: palette.text }]} numberOfLines={2}>
+        {title}
+      </Text>
+
+      {subtitle ? (
+        <Text style={[styles.zoneSubtitle, { color: palette.muted }]} numberOfLines={2}>
+          {subtitle}
+        </Text>
+      ) : null}
+
+      <Text style={[styles.zoneMeta, { color: palette.text }]} numberOfLines={1}>
+        {meta}
+      </Text>
+
+      {visibleTags.length > 0 ? (
+        <View style={styles.tagsRow}>
+          {visibleTags.map((tag) => (
+            <TradeTag key={`${kind}-${tag}`} label={tag} />
+          ))}
+        </View>
+      ) : null}
+    </View>
+  );
+}
+
+export function TradeFeedCard({ item, index, total }: TradeFeedCardProps) {
+  const { palette } = useTheme();
+  const cardPosition =
+    index != null && total != null
+      ? `${String(index + 1).padStart(2, "0")}/${String(total).padStart(2, "0")}`
+      : null;
+
+  const needMeta = compactMeta([
+    CATEGORY_LABELS[item.need.category],
+    item.need.timing,
+    MODE_LABELS[item.need.mode],
+    item.need.urgency ? URGENCY_LABELS[item.need.urgency] : undefined,
+  ]);
+
+  const offerMeta = compactMeta([
+    CATEGORY_LABELS[item.offer.category],
+    item.offer.availability,
+    MODE_LABELS[item.offer.mode],
+    item.offer.locationLabel,
+  ]);
+
+  return (
+    <View style={styles.cardBody}>
+      <View style={styles.topBar}>
+        <View style={styles.participantBlock}>
+          <Text style={[styles.eyebrow, { color: palette.muted }]} numberOfLines={1}>
+            TRADE CARD{cardPosition ? ` · ${cardPosition}` : ""}
+          </Text>
+          <Text style={[styles.participantName, { color: palette.text }]} numberOfLines={1}>
+            {item.participant.name}
+            {item.participant.rating ? ` · ${item.participant.rating.toFixed(1)}` : ""}
+          </Text>
+        </View>
+
+        {item.matchScore != null ? (
+          <View style={[styles.scorePill, { borderColor: palette.border, backgroundColor: palette.surfaceAlt }]}>
+            <Text style={[styles.scoreValue, { color: palette.text }]} numberOfLines={1}>
+              {item.matchScore}%
+            </Text>
+            <Text style={[styles.scoreLabel, { color: palette.muted }]} numberOfLines={1}>
+              match
+            </Text>
+          </View>
+        ) : null}
+      </View>
+
+      <TradeZone
+        kind="need"
+        title={item.need.title}
+        subtitle={item.need.shortDescription}
+        meta={needMeta}
+        tags={item.need.tags}
+      />
+
+      <View style={styles.exchangeRow}>
+        <View style={[styles.exchangeLine, { backgroundColor: palette.border }]} />
+        <View style={[styles.exchangeBadge, { borderColor: palette.border, backgroundColor: palette.surface }]}>
+          <Text style={[styles.exchangeText, { color: palette.text }]} numberOfLines={1}>
+            Need ↔ Offer
+          </Text>
+        </View>
+        <View style={[styles.exchangeLine, { backgroundColor: palette.border }]} />
+      </View>
+
+      <TradeZone
+        kind="offer"
+        title={item.offer.title}
+        subtitle={item.offer.includes}
+        meta={offerMeta}
+        tags={item.offer.tags}
+      />
+    </View>
+  );
+}
+
+const styles = StyleSheet.create({
+  cardBody: {
+    flex: 1,
+    paddingHorizontal: 16,
+    paddingVertical: 14,
+    gap: 10,
+  },
+
+  topBar: {
+    minHeight: 44,
+    flexDirection: "row",
+    alignItems: "center",
+    justifyContent: "space-between",
+    gap: 12,
+  },
+  participantBlock: {
+    flex: 1,
+    gap: 3,
+  },
+  eyebrow: {
+    fontSize: 9,
+    fontWeight: "900",
+    letterSpacing: 1.1,
+  },
+  participantName: {
+    fontSize: 16,
+    fontWeight: "900",
+    letterSpacing: -0.2,
+  },
+  scorePill: {
+    minWidth: 58,
+    alignItems: "center",
+    borderWidth: 1,
+    borderRadius: 16,
+    paddingHorizontal: 10,
+    paddingVertical: 7,
+  },
+  scoreValue: {
+    fontSize: 15,
+    fontWeight: "900",
+    letterSpacing: -0.2,
+    fontVariant: ["tabular-nums"],
+  },
+  scoreLabel: {
+    marginTop: 1,
+    fontSize: 9,
+    fontWeight: "900",
+    letterSpacing: 0.5,
+    textTransform: "uppercase",
+  },
+
+  zone: {
+    flex: 1,
+    minHeight: 0,
+    justifyContent: "center",
+    borderWidth: 1,
+    borderRadius: 24,
+    paddingHorizontal: 14,
+    paddingVertical: 13,
+    gap: 7,
+  },
+  zoneHeader: {
+    flexDirection: "row",
+    alignItems: "center",
+    gap: 8,
+  },
+  zoneBadge: {
+    borderWidth: 1,
+    borderRadius: 999,
+    paddingHorizontal: 8,
+    paddingVertical: 4,
+  },
+  zoneBadgeText: {
+    fontSize: 9,
+    fontWeight: "900",
+    letterSpacing: 0.8,
+  },
+  zoneHeadline: {
+    flex: 1,
+    fontSize: 12,
+    fontWeight: "900",
+    letterSpacing: 0.1,
+  },
+  zoneTitle: {
+    fontSize: 21,
+    fontWeight: "900",
+    letterSpacing: -0.45,
+    lineHeight: 24,
+  },
+  zoneSubtitle: {
+    fontSize: 12,
+    fontWeight: "700",
+    lineHeight: 16,
+  },
+  zoneMeta: {
+    fontSize: 11,
+    fontWeight: "900",
+    lineHeight: 14,
+  },
+  tagsRow: {
+    flexDirection: "row",
+    flexWrap: "wrap",
+    gap: 6,
+  },
+  tag: {
+    maxWidth: 118,
+    borderWidth: 1,
+    borderRadius: 999,
+    paddingHorizontal: 8,
+    paddingVertical: 4,
+  },
+  tagText: {
+    fontSize: 10,
+    fontWeight: "900",
+    letterSpacing: 0.1,
+  },
+
+  exchangeRow: {
+    minHeight: 34,
+    flexDirection: "row",
+    alignItems: "center",
+    justifyContent: "center",
+    gap: 8,
+  },
+  exchangeLine: {
+    flex: 1,
+    height: 1,
+  },
+  exchangeBadge: {
+    borderWidth: 1,
+    borderRadius: 999,
+    paddingHorizontal: 12,
+    paddingVertical: 7,
+  },
+  exchangeText: {
+    fontSize: 11,
+    fontWeight: "900",
+    letterSpacing: 0.2,
+  },
+});
