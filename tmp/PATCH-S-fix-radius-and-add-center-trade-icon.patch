diff --git a/features/trade/components/TradeExchangeIcon.tsx b/features/trade/components/TradeExchangeIcon.tsx
new file mode 100644
index 0000000..668486e
--- /dev/null
+++ b/features/trade/components/TradeExchangeIcon.tsx
@@ -0,0 +1,88 @@
+import React from "react";
+import { StyleSheet, View } from "react-native";
+
+type TradeExchangeIconProps = {
+  size?: number;
+  color?: string;
+  strokeWidth?: number;
+};
+
+export function TradeExchangeIcon({
+  size = 18,
+  color = "#111111",
+  strokeWidth = 2,
+}: TradeExchangeIconProps) {
+  const lineThickness = Math.max(1.5, Math.round(strokeWidth));
+  const horizontalWidth = size * 0.74;
+  const diagonalWidth = size * 0.34;
+
+  return (
+    <View style={[styles.root, { width: size, height: size }]}>
+      <View
+        style={[
+          styles.horizontal,
+          {
+            top: size * 0.28,
+            left: size * 0.12,
+            width: horizontalWidth,
+            height: lineThickness,
+            borderRadius: 999,
+            backgroundColor: color,
+          },
+        ]}
+      />
+      <View
+        style={[
+          styles.horizontal,
+          {
+            top: size * 0.56,
+            left: size * 0.12,
+            width: horizontalWidth,
+            height: lineThickness,
+            borderRadius: 999,
+            backgroundColor: color,
+          },
+        ]}
+      />
+      <View
+        style={[
+          styles.diagonal,
+          {
+            top: size * 0.12,
+            left: size * 0.56,
+            width: diagonalWidth,
+            height: lineThickness,
+            borderRadius: 999,
+            backgroundColor: color,
+            transform: [{ rotate: "45deg" }],
+          },
+        ]}
+      />
+      <View
+        style={[
+          styles.diagonal,
+          {
+            top: size * 0.69,
+            left: size * 0.10,
+            width: diagonalWidth,
+            height: lineThickness,
+            borderRadius: 999,
+            backgroundColor: color,
+            transform: [{ rotate: "45deg" }],
+          },
+        ]}
+      />
+    </View>
+  );
+}
+
+const styles = StyleSheet.create({
+  root: {
+    position: "relative",
+    alignItems: "center",
+    justifyContent: "center",
+  },
+  horizontal: {
+    position: "absolute",
+  },
+  diagonal: {
+    position: "absolute",
+  },
+});
