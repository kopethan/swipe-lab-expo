+
+const MODE_OPTIONS: TradeServiceMode[] = ["remote", "local", "hybrid"];
+const URGENCY_OPTIONS: TradeUrgency[] = ["low", "medium", "high", "urgent"];
+
+const EMPTY_QUICK_NEED: QuickNeedDraft = {
+  title: "",
+  category: "design",
+  timing: "This week",
+  mode: "remote",
+  urgency: "medium",
+  locationLabel: "Remote",
+  shortDescription: "",
