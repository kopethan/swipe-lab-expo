+    letterSpacing: 0.4,
+    textTransform: "uppercase",
+  },
+  list: {
+    gap: 14,
+  },
+  needCard: {
+    minHeight: 124,
+    justifyContent: "center",
+    borderWidth: 1,
+    borderRadius: 28,
+    paddingHorizontal: 18,
+    paddingVertical: 18,
+    gap: 8,
+  },
+  needTopRow: {
+    flexDirection: "row",
+    alignItems: "center",
+    justifyContent: "space-between",
+    gap: 10,
+  },
+  needKicker: {
+    flex: 1,
+    fontSize: 9,
+    fontWeight: "900",
+    letterSpacing: 1.1,
+  },
+  statusPill: {
+    borderWidth: 1,
+    borderRadius: 999,
+    paddingHorizontal: 9,
+    paddingVertical: 5,
+  },
+  statusText: {
+    fontSize: 9,
