+    lineHeight: 26,
+    textAlign: "center",
+  },
+  createText: {
+    maxWidth: 260,
+    fontSize: 12,
+    fontWeight: "700",
+    lineHeight: 16,
+    textAlign: "center",
+  },
+  sectionHeader: {
+    flexDirection: "row",
+    alignItems: "center",
+    justifyContent: "space-between",
+    gap: 12,
+  },
+  sectionKicker: {
+    fontSize: 10,
